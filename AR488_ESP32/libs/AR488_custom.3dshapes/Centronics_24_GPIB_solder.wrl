  children [ Shape { appearance USE Pin geometry Box { size 0.0005 0.003 0.0005 } } ]
}

# Row 1 pins — horizontal stubs (from PCB surface into connector body)
Transform {
  translation 0 0.0002 -0.001
  children [
    Shape {
      appearance USE Pin
      geometry Box { size 0.026 0.0004 0.002 }
    }
  ]
}

