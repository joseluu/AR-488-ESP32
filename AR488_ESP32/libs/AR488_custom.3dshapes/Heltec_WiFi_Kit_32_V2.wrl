#VRML V2.0 utf8
#
# Heltec WiFi Kit 32 V2 — ESP32 module with OLED
# Board: 50.2mm x 25.5mm, white PCB
# Pin headers: 2x18, 2.54mm pitch, 22.86mm row spacing
# Stands 5mm above main PCB via pin headers
#
# Footprint origin at pin 1 (0,0)
# Left row: x=0, y=0..43.18  Right row: x=22.86, y=0..43.18
# Board center: x=11.43, y=21.59
# Board extends: x from -1.32 to 24.18 (25.5mm), y from -3.51 to 46.69 (50.2mm)
#
# VRML coords (meters): X=footprint X, Y=up, Z=footprint Y

# ============================================================
# Pin headers — black plastic housings (2mm tall, on bottom of module PCB)
# Sitting on main PCB, raising the module 5mm
# ============================================================

# Left header strip (18 pins)
Transform {
  translation 0 0.004 0.02159
  children [
    Shape {
      appearance DEF BlackPlastic Appearance {
        material Material {
          diffuseColor 0.1 0.1 0.1
          specularColor 0.2 0.2 0.2
          shininess 0.3
        }
      }
      geometry Box {
        size 0.0025 0.0025 0.04572
      }
    }
  ]
}

# Right header strip (18 pins)
Transform {
  translation 0.02286 0.004 0.02159
  children [
    Shape {
      appearance USE BlackPlastic
      geometry Box {
        size 0.0025 0.0025 0.04572
      }
    }
  ]
}

# ============================================================
# Header pins — gold colored, from main PCB through headers into module
# Below header (through main PCB): 3mm
# Through header plastic: 2.5mm
# Into module PCB: 0.5mm stub
# ============================================================

# Left row pins (18 pins at x=0, z=0 to z=43.18mm)
Transform {
  translation 0 0.00125 0
  children [
    Shape {
      appearance DEF GoldPin Appearance {
        material Material {
          diffuseColor 0.85 0.75 0.45
          specularColor 0.95 0.9 0.6
          shininess 0.8
        }
      }
      geometry Box { size 0.0006 0.005 0.0006 }
    }
  ]
}
Transform {
  translation 0 0.00125 0.00254
  children [ Shape { appearance USE GoldPin geometry Box { size 0.0006 0.005 0.0006 } } ]
}
Transform {
  translation 0 0.00125 0.00508
  children [ Shape { appearance USE GoldPin geometry Box { size 0.0006 0.005 0.0006 } } ]
}
